# OpenWeatherMap API key (free tier: https://openweathermap.org/api)
OWM_API_KEY=your_openweathermap_api_key_here

# ISO-NE Web Services API credentials — the primary live load source.
# Register at https://www.iso-ne.com/participate/support/web-services-data
ISO_NE_WS_USER=your_iso_ne_username
ISO_NE_WS_PASS=your_iso_ne_password

# EIA Open Data API key — no-wait fallback live source (true NEMA-zone demand).
# Free key issued instantly: https://www.eia.gov/opendata/register.php
# Used automatically when ISO-NE Web Services credentials are absent.
EIA_API_KEY=your_eia_api_key

# Path to the original NEMA 3 project data — only needed for local model TRAINING
# (historical weather CSVs). Not required to run the deployed dashboard.
NEMA_DATA_PATH=/Users/nath011/Desktop/NEMA 3
